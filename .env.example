# PostgreSQL
POSTGRES_USER=rakshak
POSTGRES_PASSWORD=rakshak_dev_password
POSTGRES_DB=rakshak
# PostgreSQL (production / full stack with Podman)
# DATABASE_URL=postgresql://rakshak:rakshak_dev_password@127.0.0.1:5433/rakshak

# SQLite is used by default for local dev without Podman
DATABASE_URL=sqlite:///./rakshak.db

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=rakshak_dev_password

# API
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173

# LLM (optional — for conversational intelligence)
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini

# OCR (PDF scans, images — requires Tesseract: brew install tesseract tesseract-lang)
OCR_LANGUAGES=eng+kan
OCR_DPI=300
